# Neo4j连接配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# LLM配置（支持OpenAI兼容接口或Anthropic）
# 使用OpenAI兼容接口（如DeepSeek、Qwen、本地Ollama等）
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o

# 或使用Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your_anthropic_key_here
# LLM_MODEL=claude-sonnet-4-6

# Excel文件路径（相对于项目根目录）
EXCEL_FILE=数字化系统财务模型边界【抽水蓄能】v15(亏损弥补+分红预提税+净资产税+折旧摊销优化）.xlsx
